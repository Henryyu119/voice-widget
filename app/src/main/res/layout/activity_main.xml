<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="快速记录 Widget"
            android:textSize="24sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="这是配置和入口页。请在桌面添加两个 Widget：📝 文字记录、🎤 语音日记。"
            android:textSize="14sp"
            android:paddingBottom="16dp" />

        <Button
            android:id="@+id/btnOpenQuickActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="打开发送页" />

        <Button
            android:id="@+id/btnOpenTextEntry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="打开文字记录页" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Webhook URL"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvWebhookUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:background="#f0f0f0"
            android:padding="12dp"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="语音上传接口"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tvVoiceApi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textIsSelectable="true"
            android:background="#f0f0f0"
            android:padding="12dp"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
